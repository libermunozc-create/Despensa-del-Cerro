# === Copiá este archivo a .env.local y completá los valores ===
# .env.local NO se sube a git (está en .gitignore). Nunca pegues secretos en el código.

# Telegram — token que te dio @BotFather (revocá el que se filtró por chat y usá uno nuevo)
TELEGRAM_BOT_TOKEN=

# Un string largo inventado por vos. Telegram lo manda en cada llamada y nosotros lo verificamos.
# Generá uno con: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# OpenAI — key NUEVA (revocá la que se filtró). Ponele un límite de gasto mensual en OpenAI.
OPENAI_API_KEY=
# Opcionales (tienen default razonable):
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# make.com — URL del webhook del scenario "Despensa del Cerro — publicar"
MAKE_WEBHOOK_URL=

# Quién puede usar el bot: chat ids de Telegram separados por coma.
# Mandale /id al bot para ver el tuyo. Si queda vacío, NADIE puede publicar (seguro por defecto).
ALLOWED_TELEGRAM_IDS=

# --- Estos los inyecta Vercel solo al conectar el storage al proyecto ---
# Blob (imágenes públicas):
BLOB_READ_WRITE_TOKEN=
# Redis/Upstash (estado de conversación). Acepta cualquiera de los dos pares de nombres:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
